{
  "name": "claude-window-keeper",
  "version": "0.1.0",
  "description": "Claude's Window Keeper — keep your Claude Code usage window ready for long sessions. Not affiliated with Anthropic.",
  "type": "module",
  "bin": {
    "cwk": "src/cli/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node ./src/cli/index.js",
    "check": "find src test -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test \"test/**/*.test.js\"",
    "test:unit": "node --test \"test/unit/*.test.js\"",
    "test:integration": "node --test \"test/integration/*.test.js\""
  },
  "dependencies": {
    "chrono-node": "^2.7.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "github-actions",
    "cli"
  ],
  "author": "faikidine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faikidine/cwk.git"
  },
  "homepage": "https://github.com/faikidine/cwk#readme",
  "bugs": {
    "url": "https://github.com/faikidine/cwk/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
